{
  "version": "0.2.0",
  "configurations": [
    {
      "type": "node",
      "request": "launch",
      "name": "Electron: Main",
      "program": "${workspaceFolder}/electron/main.js",
      "runtimeExecutable": "${workspaceFolder}/node_modules/.bin/electron",
      "windows": {
        "runtimeExecutable": "${workspaceFolder}\\node_modules\\.bin\\electron.cmd"
      },
      "args": ["."],
      "cwd": "${workspaceFolder}/electron",
      "protocol": "inspector",
      "env": {},
      "outputCapture": "std"
    }
  ]
}
